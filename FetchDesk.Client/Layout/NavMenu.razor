<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FetchDesk</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

@* ADICIONADO: Aplicando a classe condicional @NavMenuCssClass para esconder/mostrar *@
<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="caixa">
                <span class="bi bi-cart-plus-fill-nav-menu" aria-hidden="true"></span> Caixa
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="balcao">
                <span class="bi bi-list-check-nav-menu" aria-hidden="true"></span> Balcão
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="fechamento">
                <span class="bi bi-list-checkout-nav-menu" aria-hidden="true"></span> Fechamento
            </NavLink>
        </div>

        <hr class="text-white-50 mx-3 my-2" />

        <div class="nav-item px-3">
            @* AJUSTADO: Adicionada a classe 'text-light' para corrigir a cor escura *@
            <div class="nav-link text-light" @onclick="ToggleAdminMenu" @onclick:stopPropagation="true" style="cursor: pointer;">
                <span class="bi bi-gear-fill" aria-hidden="true" style="margin-right: 0.75rem;"></span> Administrativo
                <span class="bi @(_expandAdminMenu ? "bi-chevron-up" : "bi-chevron-down") ms-auto" aria-hidden="true"></span>
            </div>
        </div>

        @if (_expandAdminMenu)
        {
            <div class="nav-item px-3 ps-4">
                <NavLink class="nav-link" href="produtos">
                    <span class="bi bi-box-seam" aria-hidden="true" style="margin-right: 0.75rem;"></span> Produtos
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool _expandAdminMenu = false;
    
    // Mantendo a lógica padrão do Blazor que controla o recolhimento total do menu
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleAdminMenu()
    {
        _expandAdminMenu = !_expandAdminMenu;
    }
}